{
  "name": "tauri-plugin-litert-api",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript bindings for tauri-plugin-litert",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ldoguin/tauri-plugin-litert"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2"
  },
  "peerDependenciesMeta": {
    "@litertjs/core": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@litertjs/core": "^2.5.0"
  }
}
